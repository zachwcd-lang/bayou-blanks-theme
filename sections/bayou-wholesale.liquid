{%- style -%}
  .bayou-wholesale {
    background-color: {{ section.settings.bg_color }};
    padding: 6rem 0;
  }

  @media screen and (min-width: 750px) {
    .bayou-wholesale {
      padding: 8rem 0;
    }
  }

  .bayou-wholesale__inner {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
  }

  @media screen and (min-width: 750px) {
    .bayou-wholesale__inner {
      grid-template-columns: 1fr 1fr;
      gap: 6rem;
      align-items: center;
    }
  }

  .bayou-wholesale__label {
    font-family: 'DM Sans', sans-serif;
    font-weight: 600;
    font-size: 1.1rem;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--color-bayou-gold);
    margin: 0 0 1.2rem;
  }

  .bayou-wholesale__heading {
    font-family: 'DM Sans', sans-serif;
    font-weight: 700;
    font-size: 2.8rem;
    line-height: 1.1;
    margin: 0 0 1.6rem;
    {%- if section.settings.bg_color == '#1A2415' or section.settings.bg_color == '#2D3B1E' -%}
      color: var(--color-bayou-offwhite);
    {%- else -%}
      color: var(--color-bayou-charcoal);
    {%- endif -%}
  }

  @media screen and (min-width: 750px) {
    .bayou-wholesale__heading {
      font-size: 3.6rem;
    }
  }

  .bayou-wholesale__subtext {
    font-size: 1.5rem;
    line-height: 1.6;
    margin: 0 0 3rem;
    {%- if section.settings.bg_color == '#1A2415' or section.settings.bg_color == '#2D3B1E' -%}
      color: var(--color-bayou-sage);
    {%- else -%}
      color: rgba(44, 44, 44, 0.7);
    {%- endif -%}
  }

  .bayou-wholesale__features {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
  }

  .bayou-wholesale__feature {
    display: flex;
    align-items: flex-start;
    gap: 1.2rem;
  }

  .bayou-wholesale__feature-icon {
    flex-shrink: 0;
    width: 3.6rem;
    height: 3.6rem;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: rgba(92, 122, 58, 0.12);
    {%- if section.settings.bg_color == '#1A2415' or section.settings.bg_color == '#2D3B1E' -%}
      background-color: rgba(92, 122, 58, 0.25);
    {%- endif -%}
  }

  .bayou-wholesale__feature-icon svg {
    width: 1.8rem;
    height: 1.8rem;
    stroke: var(--color-bayou-moss);
    fill: none;
    stroke-width: 2;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .bayou-wholesale__feature-text {
    font-family: 'DM Sans', sans-serif;
    font-weight: 500;
    font-size: 1.3rem;
    line-height: 1.4;
    {%- if section.settings.bg_color == '#1A2415' or section.settings.bg_color == '#2D3B1E' -%}
      color: var(--color-bayou-cream);
    {%- else -%}
      color: var(--color-bayou-charcoal);
    {%- endif -%}
  }

  /* Right side: CTA or form */
  .bayou-wholesale__cta-side {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .bayou-wholesale__cta-button {
    display: inline-block;
    font-family: 'DM Sans', sans-serif;
    font-weight: 600;
    font-size: 1.4rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    padding: 1.6rem 3.5rem;
    background-color: var(--color-bayou-gold);
    color: var(--color-bayou-dark);
    text-decoration: none;
    text-align: center;
    transition: background-color 0.2s ease;
  }

  .bayou-wholesale__cta-button:hover {
    background-color: #b5a55d;
    color: var(--color-bayou-dark);
  }

  /* Inline form styles */
  .bayou-wholesale__form {
    display: flex;
    flex-direction: column;
    gap: 1.2rem;
  }

  .bayou-wholesale__form input,
  .bayou-wholesale__form textarea {
    font-family: 'DM Sans', sans-serif;
    font-size: 1.4rem;
    padding: 1.2rem 1.5rem;
    border: 1px solid rgba(255, 255, 255, 0.15);
    background-color: rgba(255, 255, 255, 0.06);
    color: var(--color-bayou-cream);
    width: 100%;
  }

  {%- if section.settings.bg_color != '#1A2415' and section.settings.bg_color != '#2D3B1E' -%}
    .bayou-wholesale__form input,
    .bayou-wholesale__form textarea {
      border-color: rgba(0, 0, 0, 0.12);
      background-color: var(--color-bayou-white);
      color: var(--color-bayou-charcoal);
    }
  {%- endif -%}

  .bayou-wholesale__form input::placeholder,
  .bayou-wholesale__form textarea::placeholder {
    {%- if section.settings.bg_color == '#1A2415' or section.settings.bg_color == '#2D3B1E' -%}
      color: rgba(232, 223, 196, 0.4);
    {%- else -%}
      color: rgba(44, 44, 44, 0.4);
    {%- endif -%}
  }

  .bayou-wholesale__form textarea {
    min-height: 8rem;
    resize: vertical;
  }

  .bayou-wholesale__form button {
    font-family: 'DM Sans', sans-serif;
    font-weight: 600;
    font-size: 1.3rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    padding: 1.4rem 3rem;
    background-color: var(--color-bayou-gold);
    color: var(--color-bayou-dark);
    border: none;
    cursor: pointer;
    transition: background-color 0.2s ease;
  }

  .bayou-wholesale__form button:hover {
    background-color: #b5a55d;
  }
{%- endstyle -%}

<section class="bayou-wholesale" id="bayou-wholesale-{{ section.id }}">
  <div class="page-width bayou-wholesale__inner">
    <div class="bayou-wholesale__left">
      {%- if section.settings.label != blank -%}
        <p class="bayou-wholesale__label">{{ section.settings.label }}</p>
      {%- endif -%}

      {%- if section.settings.heading != blank -%}
        <h2 class="bayou-wholesale__heading">{{ section.settings.heading }}</h2>
      {%- endif -%}

      {%- if section.settings.subtext != blank -%}
        <p class="bayou-wholesale__subtext">{{ section.settings.subtext }}</p>
      {%- endif -%}

      <div class="bayou-wholesale__features">
        {%- for block in section.blocks -%}
          <div class="bayou-wholesale__feature" {{ block.shopify_attributes }}>
            <div class="bayou-wholesale__feature-icon">
              {%- case block.settings.icon -%}
                {%- when 'discount' -%}
                  <svg viewBox="0 0 24 24"><line x1="19" y1="5" x2="5" y2="19"></line><circle cx="6.5" cy="6.5" r="2.5"></circle><circle cx="17.5" cy="17.5" r="2.5"></circle></svg>
                {%- when 'truck' -%}
                  <svg viewBox="0 0 24 24"><rect x="1" y="3" width="15" height="13"></rect><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"></polygon><circle cx="5.5" cy="18.5" r="2.5"></circle><circle cx="18.5" cy="18.5" r="2.5"></circle></svg>
                {%- when 'package' -%}
                  <svg viewBox="0 0 24 24"><line x1="16.5" y1="9.4" x2="7.5" y2="4.21"></line><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"></path><polyline points="3.27 6.96 12 12.01 20.73 6.96"></polyline><line x1="12" y1="22.08" x2="12" y2="12"></line></svg>
                {%- when 'shirt' -%}
                  <svg viewBox="0 0 24 24"><path d="M20.38 3.46L16 2a4 4 0 01-8 0L3.62 3.46a2 2 0 00-1.34 2.23l.58 3.47a1 1 0 00.99.84H6v10h12V10h2.15a1 1 0 00.99-.84l.58-3.47a2 2 0 00-1.34-2.23z"></path></svg>
                {%- when 'zap' -%}
                  <svg viewBox="0 0 24 24"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"></polygon></svg>
                {%- else -%}
                  <svg viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"></polyline></svg>
              {%- endcase -%}
            </div>
            <span class="bayou-wholesale__feature-text">{{ block.settings.text }}</span>
          </div>
        {%- endfor -%}
      </div>
    </div>

    <div class="bayou-wholesale__cta-side">
      {%- if section.settings.mode == 'link' -%}
        {%- if section.settings.cta_heading != blank -%}
          <h3 class="bayou-wholesale__heading" style="font-size:2.2rem;">{{ section.settings.cta_heading }}</h3>
        {%- endif -%}
        {%- if section.settings.cta_text != blank -%}
          <p class="bayou-wholesale__subtext" style="margin-bottom:1rem;">{{ section.settings.cta_text }}</p>
        {%- endif -%}
        <a href="{{ section.settings.cta_link }}" class="bayou-wholesale__cta-button">
          {{ section.settings.cta_label | default: 'Request Wholesale Pricing' }}
        </a>
      {%- else -%}
        {%- if section.settings.cta_heading != blank -%}
          <h3 class="bayou-wholesale__heading" style="font-size:2.2rem;">{{ section.settings.cta_heading }}</h3>
        {%- endif -%}
        <form class="bayou-wholesale__form" action="/contact#bayou-wholesale-{{ section.id }}" method="post">
          <input type="hidden" name="form_type" value="contact">
          <input type="hidden" name="utf8" value="&#x2713;">
          <input type="hidden" name="contact[tags]" value="wholesale">
          <input type="text" name="contact[name]" placeholder="Your Name" required>
          <input type="email" name="contact[email]" placeholder="Email Address" required>
          <input type="text" name="contact[company]" placeholder="Business Name">
          <input type="text" name="contact[estimated_qty]" placeholder="Estimated Quantity">
          <textarea name="contact[body]" placeholder="Tell us about your needs..."></textarea>
          <button type="submit">{{ section.settings.cta_label | default: 'Request Pricing' }}</button>
        </form>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Bayou Wholesale CTA",
  "tag": "section",
  "class": "bayou-wholesale-section",
  "settings": [
    {
      "type": "select",
      "id": "bg_color",
      "label": "Background color",
      "options": [
        { "value": "#1A2415", "label": "Dark (Bayou Dark)" },
        { "value": "#2D3B1E", "label": "Forest" },
        { "value": "#E8DFC4", "label": "Cream" },
        { "value": "#FAF8F2", "label": "Off-white" }
      ],
      "default": "#1A2415"
    },
    {
      "type": "text",
      "id": "label",
      "label": "Label",
      "default": "For Businesses"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Bulk & Wholesale Pricing"
    },
    {
      "type": "textarea",
      "id": "subtext",
      "label": "Subtext",
      "default": "Volume discounts for screen printers, decorators, resellers, and teams. Premium Fanatics blanks shipped fast from Mississippi."
    },
    {
      "type": "select",
      "id": "mode",
      "label": "CTA mode",
      "options": [
        { "value": "link", "label": "Link to page" },
        { "value": "form", "label": "Inline inquiry form" }
      ],
      "default": "form"
    },
    {
      "type": "text",
      "id": "cta_heading",
      "label": "CTA side heading",
      "default": "Get a Custom Quote"
    },
    {
      "type": "textarea",
      "id": "cta_text",
      "label": "CTA side text (link mode only)",
      "default": "Fill out our quick form and we'll get back to you within 24 hours with pricing for your order."
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "CTA button label",
      "default": "Request Pricing"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "CTA button link (link mode only)"
    }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "options": [
            { "value": "discount", "label": "Discount" },
            { "value": "truck", "label": "Truck / Fast shipping" },
            { "value": "package", "label": "Package" },
            { "value": "shirt", "label": "Shirt / Apparel" },
            { "value": "zap", "label": "Lightning / Fast" },
            { "value": "check", "label": "Checkmark" }
          ],
          "default": "check"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Feature text",
          "default": "Volume discounts"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Bayou Wholesale CTA",
      "blocks": [
        { "type": "feature", "settings": { "icon": "discount", "text": "Tiered Volume Discounts" } },
        { "type": "feature", "settings": { "icon": "package", "text": "No Minimum Orders" } },
        { "type": "feature", "settings": { "icon": "truck", "text": "Fast Shipping from MS" } },
        { "type": "feature", "settings": { "icon": "shirt", "text": "Print-Ready Blanks" } }
      ]
    }
  ]
}
{% endschema %}
