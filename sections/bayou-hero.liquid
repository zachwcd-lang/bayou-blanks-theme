{%- style -%}
  .bayou-hero {
    position: relative;
    width: 100%;
    min-height: {{ section.settings.height_mobile }}vh;
    display: flex;
    align-items: {{ section.settings.content_position }};
    justify-content: center;
    overflow: hidden;
  }

  @media screen and (min-width: 750px) {
    .bayou-hero {
      min-height: {{ section.settings.height_desktop }}vh;
    }
  }

  .bayou-hero__media {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .bayou-hero__media img,
  .bayou-hero__media video {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 70%;
  }

  .bayou-hero__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to top,
      rgba(26, 36, 21, {{ section.settings.overlay_opacity | divided_by: 100.0 }}) 0%,
      rgba(26, 36, 21, {{ section.settings.overlay_opacity | times: 0.3 | divided_by: 100.0 }}) 100%
    );
    z-index: 1;
  }

  .bayou-hero__content {
    position: relative;
    z-index: 2;
    text-align: {{ section.settings.text_alignment }};
    padding: 4rem 2rem;
    max-width: 80rem;
    width: 100%;
  }

  .bayou-hero__heading {
    font-family: 'DM Sans', sans-serif;
    font-weight: 800;
    font-size: 3.6rem;
    line-height: 1.05;
    color: var(--color-bayou-offwhite);
    margin: 0 0 1.6rem;
    text-transform: uppercase;
    letter-spacing: -0.01em;
  }

  @media screen and (min-width: 750px) {
    .bayou-hero__heading {
      font-size: 6.4rem;
    }
  }

  .bayou-hero__subheading {
    font-family: 'DM Sans', sans-serif;
    font-weight: 400;
    font-size: 1.6rem;
    line-height: 1.5;
    color: var(--color-bayou-cream);
    margin: 0 0 2.4rem;
    max-width: 50rem;
    {%- if section.settings.text_alignment == 'center' -%}
      margin-left: auto;
      margin-right: auto;
    {%- endif -%}
  }

  @media screen and (min-width: 750px) {
    .bayou-hero__subheading {
      font-size: 1.8rem;
    }
  }

  .bayou-hero__content-card {
    display: inline-block;
    background: rgba(26, 36, 21, 0.45);
    backdrop-filter: blur(20px) saturate(1.3);
    -webkit-backdrop-filter: blur(20px) saturate(1.3);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: var(--radius-xl, 20px);
    padding: 3rem 3.5rem;
  }

  @media screen and (min-width: 750px) {
    .bayou-hero__content-card {
      padding: 4rem 4.5rem;
    }
  }

  .bayou-hero__button {
    display: inline-block;
    font-family: 'DM Sans', sans-serif;
    font-weight: 600;
    font-size: 1.3rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    padding: 1.5rem 3.5rem;
    background: rgba(255, 255, 255, 0.85);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    color: var(--color-bayou-dark);
    text-decoration: none;
    border-radius: var(--radius-md, 12px);
    border: 1px solid rgba(255, 255, 255, 0.4);
    transition: all 0.25s ease;
  }

  .bayou-hero__button:hover {
    background-color: var(--color-bayou-moss);
    color: var(--color-bayou-white);
    border-color: var(--color-bayou-moss);
    transform: translateY(-1px);
    box-shadow: 0 8px 24px rgba(92, 122, 58, 0.3);
  }
{%- endstyle -%}

<section class="bayou-hero" id="bayou-hero-{{ section.id }}">
  <div class="bayou-hero__media">
    {%- if section.settings.video != blank -%}
      {{ section.settings.video | video_tag: autoplay: true, loop: true, muted: true, playsinline: true }}
    {%- elsif section.settings.video_url != blank -%}
      <video autoplay loop muted playsinline>
        <source src="{{ section.settings.video_url }}" type="video/mp4">
      </video>
    {%- elsif section.settings.image != blank -%}
      {{ section.settings.image | image_url: width: 2000 | image_tag:
        loading: 'eager',
        sizes: '100vw',
        widths: '600,900,1200,1800,2000',
        class: 'bayou-hero__image'
      }}
    {%- elsif section.settings.image_asset != blank -%}
      <img src="{{ section.settings.image_asset | asset_url }}" alt="{{ section.settings.heading | escape }}" loading="eager" class="bayou-hero__image">
    {%- else -%}
      <div style="width:100%;height:100%;background-color:var(--color-bayou-forest);"></div>
    {%- endif -%}
  </div>

  <div class="bayou-hero__overlay"></div>

  <div class="bayou-hero__content page-width">
    <div class="bayou-hero__content-card">
      {%- if section.settings.heading != blank -%}
        <h1 class="bayou-hero__heading">{{ section.settings.heading }}</h1>
      {%- endif -%}

      {%- if section.settings.subheading != blank -%}
        <p class="bayou-hero__subheading">{{ section.settings.subheading }}</p>
      {%- endif -%}

      {%- if section.settings.button_label != blank -%}
        <a href="{{ section.settings.button_link }}" class="bayou-hero__button">
          {{ section.settings.button_label }}
        </a>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Bayou Hero",
  "tag": "section",
  "class": "bayou-hero-section",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Background image"
    },
    {
      "type": "video",
      "id": "video",
      "label": "Background video (Shopify-hosted)"
    },
    {
      "type": "url",
      "id": "video_url",
      "label": "Background video URL (external mp4)"
    },
    {
      "type": "text",
      "id": "image_asset",
      "label": "Image asset filename (from assets folder)",
      "info": "e.g. wh image.png"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Premium Blank Apparel"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Fanatics-quality blanks built for printing, embroidery, or wearing as-is."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Shop Now"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "min": 0,
      "max": 100,
      "step": 5,
      "label": "Overlay opacity",
      "default": 50
    },
    {
      "type": "range",
      "id": "height_desktop",
      "min": 40,
      "max": 100,
      "step": 5,
      "label": "Desktop height (vh)",
      "default": 85
    },
    {
      "type": "range",
      "id": "height_mobile",
      "min": 40,
      "max": 100,
      "step": 5,
      "label": "Mobile height (vh)",
      "default": 70
    },
    {
      "type": "select",
      "id": "content_position",
      "label": "Content vertical position",
      "options": [
        { "value": "flex-start", "label": "Top" },
        { "value": "center", "label": "Center" },
        { "value": "flex-end", "label": "Bottom" }
      ],
      "default": "flex-end"
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Text alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" }
      ],
      "default": "left"
    }
  ],
  "presets": [
    {
      "name": "Bayou Hero"
    }
  ]
}
{% endschema %}
